{
  "name": "nezha",
  "private": true,
  "version": "0.4.4",
  "description": "An Agent-First Application For Vibe Coding",
  "author": "Hanshuaikang",
  "homepage": "https://github.com/hanshuaikang/nezha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hanshuaikang/nezha.git"
  },
  "bugs": {
    "url": "https://github.com/hanshuaikang/nezha/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
